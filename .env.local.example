# Firebase Configuration (console.firebase.google.com)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_auth_domain_here
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_storage_bucket_here
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# Kakao Map & REST API (developers.kakao.com)
# 지도 표시용 (브라우저 키)
NEXT_PUBLIC_KAKAO_MAP_API_KEY=your_kakao_map_api_key_here
# 지하철역 검색 / 좌표→행정구역 변환용 (REST API 키)
KAKAO_REST_API_KEY=your_kakao_rest_api_key_here

# 국토교통부 TAGO Open API (버스도착정보, 버스정류소정보, 열차정보) - Backend Only
# https://www.data.go.kr
TAGO_API_KEY=your_tago_api_key_here

# 한국관광공사 TourAPI (관광정보) - Backend Only
# https://www.data.go.kr
TOUR_API_KEY=your_tour_api_key_here

# 서울 교통 공사 API (서울 지하철 실시간 도착정보) - Backend Only
# https://data.seoul.go.kr
SEOUL_METRO_API_KEY=your_seoul_metro_api_key_here
